{
  "name": "digitone-controller",
  "version": "0.4.0",
  "description": "A focused Tauri MIDI rack for Elektron instruments.",
  "scripts": {
    "dev": "tauri dev",
    "desktop": "tauri dev",
    "web:dev": "vite --host 127.0.0.1 --port 5174 --strictPort",
    "web:build": "vite build",
    "build": "tauri build",
    "typecheck": "tsc --noEmit",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test": "npm run test:rust && npm run test:e2e",
    "check": "npm run typecheck && npm run check:rust && npm run web:build",
    "midi:ports": "cargo run --quiet --manifest-path src-tauri/Cargo.toml --bin signal-rack-cli -- ports",
    "clock:bench": "cargo run --quiet --release --manifest-path src-tauri/Cargo.toml --bin signal-rack-cli -- clock-bench"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  }
}
